{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "maranello-luce-design-business",
  "version": "2.0.0",
  "description": "Ferrari Luce-inspired design system for business dashboards",
  "detailCatalog": "./components-detail.json",
  "layers": {
    "css-only": "Pure CSS components via class names, no JS required",
    "headless-js": "Vanilla JS/TS functions that render into a container element",
    "web-component": "Custom elements (mn-* tags) wrapping headless-js layer"
  },
  "themes": ["editorial", "nero", "avorio", "colorblind"],
  "webComponents": [
    "mn-chart", "mn-hbar", "mn-gauge", "mn-speedometer", "mn-gantt",
    "mn-funnel", "mn-data-table", "mn-detail-panel", "mn-okr",
    "mn-ferrari-control", "mn-date-picker", "mn-modal", "mn-toast",
    "mn-command-palette", "mn-login", "mn-chat", "mn-system-status",
    "mn-profile", "mn-map", "mn-theme-toggle", "mn-tabs", "mn-a11y"
  ],
  "cssModules": [
    "base.css", "tokens.css", "themes.css", "themes-base.css",
    "components.css", "controls.css", "forms.css", "layouts.css",
    "extended.css", "patterns.css", "animations.css", "gauge.css",
    "icons.css", "utilities.css", "accessibility.css", "composition.css",
    "charts.css", "charts-base.css", "charts-themes.css",
    "charts-live-donut-bar.css", "charts-gauge-temp-progress.css",
    "charts-treemap-radar-gantt.css", "charts-gantt-timeline.css",
    "charts-heatmap-funnel-flip.css",
    "layouts-sidebar.css", "layouts-data-table-1.css",
    "layouts-data-table-2.css", "layouts-detail-panel.css",
    "layouts-detail-panel-base.css", "layouts-command-palette.css",
    "layouts-chat-login.css", "layouts-heatmap.css",
    "layouts-horizontal-bar-1.css", "layouts-org-tree.css",
    "layouts-toolbar-drawer.css", "layouts-nav-controls.css",
    "layouts-sim-panel.css", "layouts-network.css",
    "layouts-capacity-heatmap.css", "layouts-filter-chips.css",
    "layouts-funnel.css", "layouts-page-header.css", "layouts-column.css",
    "layouts-animations.css", "layouts-notification.css",
    "controls-advanced-controls.css", "controls-buttons-switches.css",
    "controls-rotary-slider.css", "controls-segmented-led.css",
    "controls-cluster-picker.css", "controls-climate-overrides.css",
    "forms-base.css", "forms-inputs.css", "forms-checkboxes-radios.css",
    "forms-file-date-range.css", "forms-special-inputs.css",
    "forms-action-buttons.css",
    "extended-tabs-breadcrumb.css", "extended-toast-dropdown.css",
    "extended-tooltip-modal.css", "extended-avatar-spinner.css",
    "patterns-signal-binnacle.css", "patterns-strip-pod.css"
  ],
  "tsModules": {
    "public": [
      "index.ts", "charts.ts", "gantt.ts", "gauge.ts", "forms.ts", "controls.ts", "maranello.ts"
    ],
    "internal": [
      "observers.ts", "gauge-engine-class.ts",
      "speedometer-palette.ts", "speedometer-draw.ts",
      "h-bar-chart-draw.ts",
      "data-binding-events.ts", "data-binding-ui.ts",
      "icons-az.ts",
      "detail-panel.ts", "detail-panel-ui.ts", "detail-panel-editors.ts", "detail-panel-renderers.ts",
      "a11y-panel.ts", "a11y-panel-dom.ts",
      "controls-dialogs.ts", "controls-drag.ts",
      "map-view.ts", "map-view-events.ts", "map-view-helpers.ts"
    ]
  },
  "components": [
    { "name": "Sparkline", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "sparkline", "cssImport": "maranello-luce-design-business/css/charts.css", "wcTag": "mn-chart", "dataContract": "SparklineOptions", "whenToUse": ["inline KPI trends", "sparkline in table cells"] },
    { "name": "Donut", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "donut", "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css", "wcTag": "mn-chart", "dataContract": "DonutSegment[]", "whenToUse": ["proportional breakdown", "completion percentage"] },
    { "name": "BarChart", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "barChart", "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css", "wcTag": "mn-chart", "dataContract": "BarDataItem[]", "whenToUse": ["category comparison", "monthly totals"] },
    { "name": "AreaChart", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "areaChart", "cssImport": "maranello-luce-design-business/css/charts.css", "wcTag": "mn-chart", "dataContract": "AreaDataset[]", "whenToUse": ["time series overlay", "trend comparison"] },
    { "name": "Radar", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "radar", "cssImport": "maranello-luce-design-business/css/charts-treemap-radar-gantt.css", "wcTag": "mn-chart", "dataContract": "RadarDataItem[]", "whenToUse": ["multi-dimensional scoring", "competency assessment"] },
    { "name": "Bubble", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "bubble", "cssImport": "maranello-luce-design-business/css/charts.css", "wcTag": "mn-chart", "dataContract": "BubbleDataItem[]", "whenToUse": ["3D data visualization", "market mapping"] },
    { "name": "LiveGraph", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "liveGraph", "cssImport": "maranello-luce-design-business/css/charts-live-donut-bar.css", "wcTag": "mn-chart", "dataContract": "LiveGraphOptions", "whenToUse": ["real-time monitoring", "streaming data"] },
    { "name": "HalfGauge", "layer": "headless-js", "import": "maranello-luce-design-business/charts", "function": "halfGauge", "cssImport": "maranello-luce-design-business/css/charts-gauge-temp-progress.css", "wcTag": "mn-chart", "dataContract": "HalfGaugeOptions", "whenToUse": ["score display", "capacity meter"] },
    { "name": "HBarChart", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "hBarChart", "cssImport": "maranello-luce-design-business/css/layouts-horizontal-bar-1.css", "wcTag": "mn-hbar", "dataContract": "HBarChartOptions", "whenToUse": ["ranked lists", "horizontal comparison"] },
    { "name": "FerrariGauge", "layer": "headless-js", "import": "maranello-luce-design-business/gauge", "function": "FerrariGauge", "cssImport": "maranello-luce-design-business/css/gauge.css", "wcTag": "mn-gauge", "dataContract": "GaugeConfig", "whenToUse": ["KPI display", "score visualization"] },
    { "name": "Speedometer", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "speedometer", "cssImport": "maranello-luce-design-business/css/charts-gauge-temp-progress.css", "wcTag": "mn-speedometer", "dataContract": "SpeedometerOptions", "whenToUse": ["velocity metrics", "performance gauge"] },
    { "name": "Gantt", "layer": "headless-js", "import": "maranello-luce-design-business/gantt", "function": "gantt", "cssImport": "maranello-luce-design-business/css/charts-gantt-timeline.css", "wcTag": "mn-gantt", "dataContract": "GanttTask[]", "whenToUse": ["project timeline", "resource planning"] },
    { "name": "Funnel", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "funnel", "cssImport": "maranello-luce-design-business/css/charts-heatmap-funnel-flip.css", "wcTag": "mn-funnel", "dataContract": "SankeyData", "whenToUse": ["pipeline visualization", "conversion funnel"] },
    { "name": "DataTable", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "dataTable", "cssImport": "maranello-luce-design-business/css/layouts-data-table-1.css", "wcTag": "mn-data-table", "dataContract": "DataTableOptions", "whenToUse": ["tabular data", "CRUD listings"] },
    { "name": "DetailPanel", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "openDetailPanel", "cssImport": "maranello-luce-design-business/css/layouts-detail-panel.css", "wcTag": "mn-detail-panel", "dataContract": "DetailPanelOptions", "whenToUse": ["record detail view", "edit form overlay"] },
    { "name": "OkrPanel", "layer": "headless-js", "import": "maranello-luce-design-business", "cssImport": "maranello-luce-design-business/css/layouts-detail-panel.css", "wcTag": "mn-okr", "dataContract": "OkrPanelOptions", "whenToUse": ["OKR tracking", "goal dashboards"] },
    { "name": "Manettino", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "manettino", "cssImport": "maranello-luce-design-business/css/controls.css", "wcTag": "mn-ferrari-control", "dataContract": "ManettinoOptions", "whenToUse": ["mode selector", "branded control"] },
    { "name": "SteppedRotary", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "steppedRotary", "cssImport": "maranello-luce-design-business/css/controls.css", "wcTag": "mn-ferrari-control", "dataContract": "SteppedDialOptions", "whenToUse": ["stepped selection", "discrete value dial"] },
    { "name": "CruiseLever", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "cruiseLever", "cssImport": "maranello-luce-design-business/css/controls.css", "wcTag": "mn-ferrari-control", "dataContract": "CruiseLeverOptions", "whenToUse": ["multi-step control", "vertical mode switch"] },
    { "name": "ToggleLever", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "toggleLever", "cssImport": "maranello-luce-design-business/css/controls.css", "wcTag": "mn-ferrari-control", "dataContract": "FerrariToggleOptions", "whenToUse": ["boolean toggle", "on/off switch"] },
    { "name": "Forms", "layer": "headless-js", "import": "maranello-luce-design-business/forms", "function": "initForms", "cssImport": "maranello-luce-design-business/css/forms.css", "dataContract": "FormValidators", "whenToUse": ["data entry forms", "multi-step wizards"] },
    { "name": "DatePicker", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "datePicker", "cssImport": "maranello-luce-design-business/css/forms-file-date-range.css", "wcTag": "mn-date-picker", "dataContract": "DatePickerOptions", "whenToUse": ["date selection", "date range filtering"] },
    { "name": "Modal", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "openModal", "cssImport": "maranello-luce-design-business/css/extended-tooltip-modal.css", "wcTag": "mn-modal", "dataContract": "string (backdrop element ID)", "whenToUse": ["confirmation dialogs", "alert modals"] },
    { "name": "Toast", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "toast", "cssImport": "maranello-luce-design-business/css/extended-toast-dropdown.css", "wcTag": "mn-toast", "dataContract": "ToastOptions", "whenToUse": ["success messages", "error alerts"] },
    { "name": "CommandPalette", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "commandPalette", "cssImport": "maranello-luce-design-business/css/layouts-command-palette.css", "wcTag": "mn-command-palette", "dataContract": "string (palette element ID)", "whenToUse": ["quick actions", "global search"] },
    { "name": "LoginScreen", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "loginScreen", "cssImport": "maranello-luce-design-business/css/layouts-chat-login.css", "wcTag": "mn-login", "dataContract": "LoginScreenOptions", "whenToUse": ["application login page", "SSO authentication"] },
    { "name": "AIChat", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "buildUI", "cssImport": "maranello-luce-design-business/css/layouts-chat-login.css", "wcTag": "mn-chat", "dataContract": "AIChatOptions", "whenToUse": ["AI assistant", "chat widget"] },
    { "name": "SystemStatus", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "systemStatus", "cssImport": "maranello-luce-design-business/css/layouts-chat-login.css", "wcTag": "mn-system-status", "dataContract": "SystemStatusOptions", "whenToUse": ["service monitoring", "status bar widget"] },
    { "name": "ProfileMenu", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "profileMenu", "cssImport": "maranello-luce-design-business/css/extended-toast-dropdown.css", "wcTag": "mn-profile", "dataContract": "ProfileMenuOptions", "whenToUse": ["user profile dropdown", "navigation header"] },
    { "name": "MapView", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "mapView", "cssImport": "maranello-luce-design-business/css/layouts-heatmap.css", "wcTag": "mn-map", "dataContract": "MapViewOptions", "whenToUse": ["geographic data", "office locations"] },
    { "name": "FlipCounter", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "flipCounter", "cssImport": "maranello-luce-design-business/css/charts-heatmap-funnel-flip.css", "dataContract": "FlipCounterOptions", "whenToUse": ["live counters", "animated numbers"] },
    { "name": "ProgressRing", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "progressRing", "cssImport": "maranello-luce-design-business/css/charts-gauge-temp-progress.css", "dataContract": "ProgressRingOptions", "whenToUse": ["progress indicator", "completion percentage"] },
    { "name": "ThemeToggle", "layer": "headless-js", "import": "maranello-luce-design-business", "function": "initThemeToggle", "cssImport": "maranello-luce-design-business/css/themes.css", "wcTag": "mn-theme-toggle", "dataContract": "string (toggle button ID)", "whenToUse": ["theme switching", "dark/light toggle"] },
    { "name": "OrgTree", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "initOrgTree", "cssImport": "maranello-luce-design-business/css/layouts-org-tree.css", "dataContract": "OrgTreeOptions", "whenToUse": ["org chart", "hierarchical navigation"] },
    { "name": "Drawer", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "openDrawer", "cssImport": "maranello-luce-design-business/css/layouts-toolbar-drawer.css", "dataContract": "string (drawer element ID)", "whenToUse": ["mobile navigation", "filter panel"] },
    { "name": "A11yPanel", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "a11yPanel", "cssImport": "maranello-luce-design-business/css/accessibility.css", "wcTag": "mn-a11y", "dataContract": "A11yPanelController", "whenToUse": ["accessibility settings", "font size / contrast controls"] },
    { "name": "Observers", "layer": "headless-js", "import": "maranello-luce-design-business", "functions": ["initGauges", "initScrollReveal", "initNavTracking", "autoContrast", "relativeLuminance"], "whenToUse": ["lazy gauge init", "scroll reveal", "nav highlighting", "WCAG auto-contrast"] },
    { "name": "Dropdown", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "initDropdown", "cssImport": "maranello-luce-design-business/css/extended-toast-dropdown.css", "dataContract": "DropdownController", "whenToUse": ["dropdown menus", "select widgets"] },
    { "name": "TabsInit", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "initTabs", "cssImport": "maranello-luce-design-business/css/extended-tabs-breadcrumb.css", "whenToUse": ["tabbed navigation", "content panels"] },
    { "name": "RotaryKnob", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "initRotary", "cssImport": "maranello-luce-design-business/css/controls-rotary-slider.css", "dataContract": "RotaryController", "whenToUse": ["drag rotary knob", "stepped dial"] },
    { "name": "SliderControl", "layer": "headless-js", "import": "maranello-luce-design-business/controls", "function": "initSlider", "cssImport": "maranello-luce-design-business/css/controls-rotary-slider.css", "dataContract": "SliderController", "whenToUse": ["linear slider", "range input"] },
    { "name": "DataBinding", "layer": "headless-js", "import": "maranello-luce-design-business", "functions": ["emit", "on", "off", "bind", "autoBind", "onDrillDown"], "whenToUse": ["event bus", "data-driven DOM updates", "drill-down interactions"] },
    { "name": "DataBindingUI", "layer": "headless-js", "import": "maranello-luce-design-business", "functions": ["updateGauge", "bindChart", "autoBindSliders", "bindControl"], "whenToUse": ["gauge live update", "chart data polling", "control REST binding"] },
    { "name": "Icons", "layer": "headless-js", "import": "maranello-luce-design-business", "exports": ["icons", "actionIcons", "dataIcons", "navIcons", "objectIcons", "statusIcons", "azIcons"], "whenToUse": ["SVG icon injection", "icon buttons", "icon sets"] },
    { "name": "Sidebar", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/layouts-sidebar.css", "whenToUse": ["main navigation", "app sidebar"] },
    { "name": "Cards", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/components-dividers-tags-cards.css", "whenToUse": ["content cards", "dashboard tiles"] },
    { "name": "ScrollReveal", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/animations.css", "whenToUse": ["scroll animations", "content reveal"] },
    { "name": "NavTracking", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/layouts-nav-controls.css", "whenToUse": ["breadcrumbs", "step indicators"] },
    { "name": "Heatmap", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/layouts-heatmap.css", "whenToUse": ["data density visualization", "activity grids"] },
    { "name": "Treemap", "layer": "css-only", "cssImport": "maranello-luce-design-business/css/charts-treemap-radar-gantt.css", "whenToUse": ["hierarchical data", "portfolio allocation"] }
  ]
}
