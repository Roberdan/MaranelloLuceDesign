{
  "name": "@convergio/design-elements",
  "version": "6.3.2",
  "description": "Maranello Luce Design \u2014 31 Web Components + headless viz/domain API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "types": "./src/react.d.ts"
    },
    "./wc": {
      "types": "./dist/types/wc/index.d.ts",
      "import": "./dist/esm/wc/index.js"
    },
    "./wc/*": {
      "types": "./dist/types/wc/*.d.ts",
      "import": "./dist/esm/wc/*.js"
    },
    "./register-all": {
      "types": "./dist/types/wc/register-all.d.ts",
      "import": "./dist/esm/wc/register-all.js"
    },
    "./knowledge": "./dist/knowledge/ckb.json",
    "./css": "./dist/css/index.css",
    "./css/*": "./dist/css/*"
  },
  "peerDependencies": {
    "@convergio/design-tokens": "^6.0.0"
  },
  "devDependencies": {
    "@convergio/design-tokens": "workspace:*"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs && node ../../scripts/build-wc.mjs && tsc --emitDeclarationOnly && npm run build:css && node ../../scripts/generate-ckb.mjs",
    "build:css": "node ../../scripts/build-css.mjs && cp -r ../../dist/css dist/css",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "license": "MPL-2.0"
}
