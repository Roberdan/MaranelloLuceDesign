  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#4a6a8f", "fontStyle": "italic"} },
    { "scope": ["string", "string.quoted", "string.template"], "settings": {"foreground": "#b4fa72"} },
    { "scope": ["constant.numeric", "constant.language"], "settings": {"foreground": "#FFC72C"} },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type"], "settings": {"foreground": "#FFC72C"} },
    { "scope": ["entity.name.function", "support.function"], "settings": {"foreground": "#7eb8f7"} },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": {"foreground": "#5dd8c0"} },
    { "scope": ["variable", "variable.other"], "settings": {"foreground": "#e8eaf6"} },
    { "scope": ["entity.name.tag"], "settings": {"foreground": "#ff8272"} },
    { "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#FFC72C", "fontStyle": "italic"} },
    { "scope": ["support.type.property-name.json"], "settings": {"foreground": "#7eb8f7"} },
    { "scope": ["markup.heading"], "settings": {"foreground": "#FFC72C", "fontStyle": "bold"} },
    { "scope": "token.error-token", "settings": {"foreground": "#ff8272"} },
    { "scope": "token.warn-token", "settings": {"foreground": "#FFC72C"} }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#7eb8f7",
    "variable": "#e8eaf6",
    "variable.readonly": "#FFC72C",
    "parameter": {"foreground": "#b8c9e8", "italic": true},
    "property": "#b8c9e8",
    "type": "#5dd8c0",
    "class": "#5dd8c0",
    "interface": {"foreground": "#5dd8c0", "italic": true},
    "enum": "#5dd8c0",
    "enumMember": "#FFC72C",
    "namespace": "#5dd8c0",
    "keyword": "#FFC72C",
    "string": "#b4fa72",
    "number": "#FFC72C",
    "comment": {"foreground": "#4a6a8f", "italic": true}
  }
}
