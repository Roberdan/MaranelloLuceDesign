    "breadcrumbPicker.background": "#0a0a0a",
    "quickInput.background": "#0a0a0a",
    "quickInput.foreground": "#fafafa",
    "quickInputTitle.background": "#0a0a0a",
    "quickInputList.focusBackground": "#FFC72C33",
    "focusBorder": "#FFC72C66",
    "foreground": "#fafafa",
    "descriptionForeground": "#cccccc",
    "icon.foreground": "#cccccc",
    "errorForeground": "#DC0000",
    "progressBar.background": "#FFC72C",
    "textLink.foreground": "#FFC72C",
    "textLink.activeForeground": "#ffd966",
    "selection.background": "#FFC72C44",
    "settings.headerForeground": "#fafafa",
    "settings.modifiedItemIndicator": "#FFC72C"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#666666", "fontStyle": "italic"} },
    { "scope": ["string", "string.quoted", "string.template"], "settings": {"foreground": "#00A651"} },
    { "scope": ["constant.numeric", "constant.language"], "settings": {"foreground": "#FFC72C"} },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type"], "settings": {"foreground": "#FFC72C"} },
    { "scope": ["entity.name.function", "support.function"], "settings": {"foreground": "#fafafa"} },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": {"foreground": "#5dd8c0"} },
    { "scope": ["variable", "variable.other"], "settings": {"foreground": "#fafafa"} },
    { "scope": ["entity.name.tag"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#FFC72C", "fontStyle": "italic"} },
    { "scope": ["support.type.property-name.json"], "settings": {"foreground": "#FFC72C"} },
    { "scope": ["markup.heading"], "settings": {"foreground": "#FFC72C", "fontStyle": "bold"} },
    { "scope": "token.error-token", "settings": {"foreground": "#DC0000"} },
    { "scope": "token.warn-token", "settings": {"foreground": "#FFC72C"} }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#fafafa",
    "variable": "#fafafa",
    "variable.readonly": "#FFC72C",
    "parameter": {"foreground": "#cccccc", "italic": true},
    "property": "#cccccc",
    "type": "#5dd8c0",
    "class": "#5dd8c0",
    "interface": {"foreground": "#5dd8c0", "italic": true},
    "enum": "#5dd8c0",
    "enumMember": "#FFC72C",
    "namespace": "#5dd8c0",
    "keyword": "#FFC72C",
    "string": "#00A651",
    "number": "#FFC72C",
    "comment": {"foreground": "#666666", "italic": true}
  }
}
