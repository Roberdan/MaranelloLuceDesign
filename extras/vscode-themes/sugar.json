    "quickInput.foreground": "#111111",
    "quickInputTitle.background": "#d0d0d4",
    "quickInputList.focusBackground": "#00000022",
    "focusBorder": "#00000066",
    "foreground": "#111111",
    "descriptionForeground": "#333333",
    "icon.foreground": "#333333",
    "errorForeground": "#DC0000",
    "progressBar.background": "#000000",
    "textLink.foreground": "#2e7dad",
    "textLink.activeForeground": "#4499cc",
    "selection.background": "#00000033",
    "settings.headerForeground": "#111111",
    "settings.modifiedItemIndicator": "#000000"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#888890", "fontStyle": "italic"} },
    { "scope": ["string", "string.quoted", "string.template"], "settings": {"foreground": "#00A651"} },
    { "scope": ["constant.numeric", "constant.language"], "settings": {"foreground": "#7b5ea7"} },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type"], "settings": {"foreground": "#000000", "fontStyle": "bold"} },
    { "scope": ["entity.name.function", "support.function"], "settings": {"foreground": "#2e7dad"} },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": {"foreground": "#0e7c6b"} },
    { "scope": ["variable", "variable.other"], "settings": {"foreground": "#111111"} },
    { "scope": ["entity.name.tag"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#b8860b", "fontStyle": "italic"} },
    { "scope": ["support.type.property-name.json"], "settings": {"foreground": "#000000"} },
    { "scope": ["markup.heading"], "settings": {"foreground": "#000000", "fontStyle": "bold"} },
    { "scope": "token.error-token", "settings": {"foreground": "#DC0000"} },
    { "scope": "token.warn-token", "settings": {"foreground": "#b8860b"} }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#2e7dad",
    "variable": "#111111",
    "variable.readonly": "#7b5ea7",
    "parameter": {"foreground": "#333333", "italic": true},
    "property": "#333333",
    "type": "#0e7c6b",
    "class": "#0e7c6b",
    "interface": {"foreground": "#0e7c6b", "italic": true},
    "enum": "#0e7c6b",
    "enumMember": "#7b5ea7",
    "namespace": "#0e7c6b",
    "keyword": "#000000",
    "string": "#00A651",
    "number": "#7b5ea7",
    "comment": {"foreground": "#888890", "italic": true}
  }
}
