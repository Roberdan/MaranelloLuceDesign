    "quickInput.foreground": "#111111",
    "quickInputTitle.background": "#f0e6d0",
    "quickInputList.focusBackground": "#DC000022",
    "focusBorder": "#DC000066",
    "foreground": "#111111",
    "descriptionForeground": "#333333",
    "icon.foreground": "#333333",
    "errorForeground": "#DC0000",
    "progressBar.background": "#DC0000",
    "textLink.foreground": "#DC0000",
    "textLink.activeForeground": "#ff2222",
    "selection.background": "#DC000033",
    "settings.headerForeground": "#111111",
    "settings.modifiedItemIndicator": "#DC0000"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#999080", "fontStyle": "italic"} },
    { "scope": ["string", "string.quoted", "string.template"], "settings": {"foreground": "#00A651"} },
    { "scope": ["constant.numeric", "constant.language"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["entity.name.function", "support.function"], "settings": {"foreground": "#2e7dad"} },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": {"foreground": "#0e7c6b"} },
    { "scope": ["variable", "variable.other"], "settings": {"foreground": "#111111"} },
    { "scope": ["entity.name.tag"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#b8860b", "fontStyle": "italic"} },
    { "scope": ["support.type.property-name.json"], "settings": {"foreground": "#DC0000"} },
    { "scope": ["markup.heading"], "settings": {"foreground": "#DC0000", "fontStyle": "bold"} },
    { "scope": "token.error-token", "settings": {"foreground": "#DC0000"} },
    { "scope": "token.warn-token", "settings": {"foreground": "#b8860b"} }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#2e7dad",
    "variable": "#111111",
    "variable.readonly": "#DC0000",
    "parameter": {"foreground": "#333333", "italic": true},
    "property": "#333333",
    "type": "#0e7c6b",
    "class": "#0e7c6b",
    "interface": {"foreground": "#0e7c6b", "italic": true},
    "enum": "#0e7c6b",
    "enumMember": "#DC0000",
    "namespace": "#0e7c6b",
    "keyword": "#DC0000",
    "string": "#00A651",
    "number": "#DC0000",
    "comment": {"foreground": "#999080", "italic": true}
  }
}
