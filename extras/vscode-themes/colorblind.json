    "selection.background": "#0072B244",
    "settings.headerForeground": "#fafafa",
    "settings.modifiedItemIndicator": "#0072B2"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#666666", "fontStyle": "italic"} },
    { "scope": ["string", "string.quoted", "string.template"], "settings": {"foreground": "#009E73"} },
    { "scope": ["constant.numeric", "constant.language"], "settings": {"foreground": "#E69F00"} },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type"], "settings": {"foreground": "#0072B2"} },
    { "scope": ["entity.name.function", "support.function"], "settings": {"foreground": "#56B4E9"} },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": {"foreground": "#CC79A7"} },
    { "scope": ["variable", "variable.other"], "settings": {"foreground": "#fafafa"} },
    { "scope": ["entity.name.tag"], "settings": {"foreground": "#D55E00"} },
    { "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#E69F00", "fontStyle": "italic"} },
    { "scope": ["support.type.property-name.json"], "settings": {"foreground": "#0072B2"} },
    { "scope": ["markup.heading"], "settings": {"foreground": "#0072B2", "fontStyle": "bold"} },
    { "scope": "token.error-token", "settings": {"foreground": "#D55E00"} },
    { "scope": "token.warn-token", "settings": {"foreground": "#E69F00"} }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#56B4E9",
    "variable": "#fafafa",
    "variable.readonly": "#E69F00",
    "parameter": {"foreground": "#cccccc", "italic": true},
    "property": "#cccccc",
    "type": "#CC79A7",
    "class": "#CC79A7",
    "interface": {"foreground": "#CC79A7", "italic": true},
    "enum": "#CC79A7",
    "enumMember": "#E69F00",
    "namespace": "#CC79A7",
    "keyword": "#0072B2",
    "string": "#009E73",
    "number": "#E69F00",
    "comment": {"foreground": "#666666", "italic": true}
  }
}
