    "quickInput.foreground": "#fafafa",
    "quickInputTitle.background": "#0a0a0a",
    "quickInputList.focusBackground": "#0072B233",
    "focusBorder": "#0072B266",
    "foreground": "#fafafa",
    "descriptionForeground": "#cccccc",
    "icon.foreground": "#cccccc",
    "errorForeground": "#D55E00",
    "progressBar.background": "#0072B2",
    "textLink.foreground": "#56B4E9",
